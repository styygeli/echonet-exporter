# ECHONET Lite Exporter – example environment
# Copy to .env and set your device IPs and options.

# Listen address (default :9191)
ECHONET_LISTEN_ADDR=:9191

# Scrape timeout in seconds (default 15)
ECHONET_SCRAPE_TIMEOUT_SEC=15

# Devices: JSON array of { "name", "ip", "class" [, "labels": {} ] }
# Classes: storage_battery (EP Cube battery), home_solar (EP Cube solar), home_ac (Daikin/Mitsubishi AC)
ECHONET_DEVICES='[
  {"name":"epcube_battery","ip":"192.168.1.10","class":"storage_battery"},
  {"name":"epcube_solar","ip":"192.168.1.10","class":"home_solar"},
  {"name":"living_ac","ip":"192.168.1.20","class":"home_ac"}
]'
